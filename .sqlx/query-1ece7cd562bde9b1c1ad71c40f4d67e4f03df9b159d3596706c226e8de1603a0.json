  "query": "SELECT r.id, r.kind, r.title, r.author, r.url, r.file_path, r.added_at\n         FROM resources r\n         JOIN resource_tags rt ON rt.resource_id = r.id\n         JOIN tags t ON t.id = rt.tag_id\n         WHERE t.name = ? COLLATE NOCASE\n         ORDER BY r.added_at DESC",
